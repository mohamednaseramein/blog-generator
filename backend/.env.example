# Supabase — get these from your Supabase project Settings > API
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Backend only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...<service-role-jwt>

# Browser-safe — used for frontend build args (public key)
SUPABASE_ANON_KEY=eyJ...<anon-jwt>

# Optional: direct Postgres URL (migrations/maintenance)
SUPABASE_DB_URL=postgresql://postgres.<your-project-ref>:<password>@<host>:5432/postgres

# Backend runtime
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# AI
ANTHROPIC_API_KEY=sk-ant-...<your-key>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Auth
JWT_SECRET=<a-long-random-secret-min-32-chars>

# Frontend build-time public var (optional)
VITE_BASE_URL=http://localhost:5173
# Copy to backend/.env (next to this file).
# Run docker compose as: docker compose --env-file backend/.env up
# Convention + security: docs/environment-configuration.md (AgDR-0017)
#
# Supabase — get these from your Supabase project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # backend only — never expose to browser
SUPABASE_ANON_KEY=your-anon-key                   # safe for frontend

# Supabase direct PostgreSQL connection — used by db:migrate only
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Backend
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional. Defaults to claude-sonnet-4-6 (same quality as before). Set to claude-haiku-4-5-20251001 locally to cut cost; set explicitly in prod if you want a fixed pin.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Auth (EP-04)
JWT_SECRET=a-long-random-secret-min-32-chars
